# --- Required ---
# Finnhub free key: https://finnhub.io/register
FINNHUB_API_KEY=yourd7isd89r01qn2qav7j1gd7isd89r01qn2qav7j20

# Discord webhook URL for alerts
# Server settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1497544983060676649/ZpPp8HVV3lOH29Q_M99DZLEqaHXrLLvhnvq9YdEcA7qMq8Os19G2wt3U4tVOY44LOKfM

# --- Optional ---
# Polygon free key (5 req/min) — used as fallback if set
POLYGON_API_KEY=

# SEC EDGAR requires a User-Agent with contact email
SEC_USER_AGENT=Your Name your_email@example.com

# Scanner config — base filters (apply to both lanes)
SCAN_PRICE_MIN=3
SCAN_PRICE_MAX=20
SCAN_MAX_FLOAT=30000000
SCAN_MIN_GAP_PCT=10
SCAN_MIN_PREMARKET_VOLUME=50000
SCAN_MIN_RELATIVE_VOLUME=2.0

# Lane toggles
ENABLE_LONG_LANE=true
ENABLE_SHORT_LANE=true

# Long lane — minimum bullish news score required to qualify on news
# (pure technical breakouts of >20% gap + >5x rvol bypass this)
LONG_MIN_BULLISH_SCORE=10

# Short lane
# Minimum gap % to consider any short setup
SHORT_MIN_GAP_PCT=30
# Bearish news score that triggers news-fade short
SHORT_MIN_BEARISH_SCORE=15
# Pure parabolic (no news context) gap threshold for fades
SHORT_PARABOLIC_EXTENSION_PCT=60

# Account
ACCOUNT_EQUITY=800
MAX_RISK_PER_TRADE_PCT=2.0
MAX_POSITION_SIZE_PCT=25.0

# Re-alert thresholds (after a ticker's first alert this session)
# Re-ping if price moves this % from the last alert price
REALERT_PRICE_PCT=5.0
# Re-ping if premarket volume doubles since last alert
REALERT_VOLUME_MULTIPLE=2.0
# Minimum seconds between alerts for the same ticker (anti-spam)
REALERT_COOLDOWN_SECONDS=300

# --- Conviction filtering ---
# Minimum conviction tier to send to Discord. high | medium | low
# Default HIGH means only the cream gets pinged. CLI table shows everything.
DISCORD_MIN_CONVICTION=high
# Score thresholds for tiering (computed by scanner)
HIGH_CONVICTION_MIN_SCORE=60
MEDIUM_CONVICTION_MIN_SCORE=35

# --- Float rotation ---
ROTATION_WARN_THRESHOLD=1.0
ROTATION_PARABOLIC_THRESHOLD=5.0

# --- Opening Range Breakout ---
ORB_MINUTES=5

# --- Risk circuit breakers ---
# Stop trading once daily P&L reaches this loss % of equity
DAILY_LOSS_LIMIT_PCT=6.0
# Cooldown after 2 consecutive losses
CONSECUTIVE_LOSS_COOLDOWN_MINUTES=30

# --- Trading window (NY local time, 24h) ---
# Outside this window the scanner still ticks (and silently updates the
# live status tile if enabled), but new-message Discord notifications
# are suppressed.
TRADING_WINDOW_START=04:00
TRADING_WINDOW_END=10:00

# Session TOP PICK: % a new candidate must beat the current leader by to take over
SESSION_TOP_PICK_DELTA_PCT=5.0

# Live status tile: a single Discord message edited in-place each scan.
# Always reflects the current top pick + ranked list. Edits don't ping
# you — pin it as a silent dashboard.
ENABLE_LIVE_TILE=true

# OPTIONAL: dedicated webhook for the live tile. Recommended setup is
# two Discord channels: #premarket-status (with this webhook here) and
# #premarket-alerts (with DISCORD_WEBHOOK_URL above). The status channel
# only ever has the one auto-edited live tile message — permanently
# visible. Leave empty to post the live tile in the same channel as alerts.
LIVE_TILE_WEBHOOK_URL=

# --- Auto-scheduler (runs inside the scan loop) ---
# IBKR Flex auto-import: pull fills every N minutes during market hours
AUTO_IBKR_IMPORT_MINUTES=10
# Daily review auto-post: NY time after which today's review will fire
AUTO_DAILY_REVIEW_AFTER=16:30
# Auto backtest: weekday (0=Mon..6=Sun) and NY time after which to run
AUTO_BACKTEST_WEEKDAY=6
AUTO_BACKTEST_AFTER=18:00

# --- Short interest enrichment ---
ENABLE_SHORT_INTEREST=true

# --- IBKR Flex Web Service auto-import ---
# See README. Token + Query ID from IBKR Account Management.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# --- Backtest ---
# Free Polygon.io key (5 req/min) for historical 1m bars
POLYGON_BACKTEST_KEY=
